# Copy to .env and fill in values before running docker compose up.
# On EC2 this file is written by Terraform and refreshed by deploy.sh.

# ── Docker image ───────────────────────────────────────────────────────────────
# Locally: build with `docker build -t sloopquest-api:local backend/`
# EC2: set automatically to the ECR URL by Terraform
API_IMAGE=sloopquest-api:local

# ── API domain (used by Caddy) ─────────────────────────────────────────────────
# Locally: localhost (Caddy uses internal CA for HTTPS)
# EC2: set automatically by Terraform (e.g. api.sloopquest.app)
API_DOMAIN=localhost

# ── Postgres (used by both the db service and the api/worker) ──────────────────
POSTGRES_DB=sloopquest
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DB_NAME=sloopquest
DB_USER=postgres
DB_PASSWORD=postgres

# ── App ────────────────────────────────────────────────────────────────────────
ENV=local
AWS_REGION=us-east-1
S3_MEDIA_BUCKET=
APP_SECRETS_ARN=

# ── SES ────────────────────────────────────────────────────────────────────────
SES_FROM_EMAIL=noreply@sloopquest.app
SES_REPLY_TO_EMAIL=support@sloopquest.app
SES_CONFIGURATION_SET=

# ── URLs ───────────────────────────────────────────────────────────────────────
FRONTEND_ORIGIN=http://localhost:5173
SUCCESS_REDIRECT_URL=http://localhost:5173
API_BASE_URL=http://localhost:8000

# ── Secrets (required — get from a team member or Secrets Manager) ─────────────
SECRET_KEY=
WEBHOOK_SECRET=
ANTHROPIC_API_KEY=

# ── BetterStack (optional — omit to disable telemetry) ────────────────────────
BETTERSTACK_OTLP_INGESTING_HOST=
BETTERSTACK_OTLP_SOURCE_TOKEN=
